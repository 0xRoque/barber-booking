datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  role          String    @default("CLIENT")
  image         String?
  emailVerified DateTime?
  timeSlots TimeSlot[]
  bookings  Booking[]
  accounts  Account[]
  sessions  Session[]
}

model TimeSlot {
  id        String   @id @default(cuid())
  barberId  String
  barber    User     @relation(fields: [barberId], references: [id])
  date      DateTime
  startTime DateTime
  endTime   DateTime
  isBlocked Boolean
  booking   Booking?
}

model Booking {
  id       String        @id @default(cuid())
  clientId String
  client   User          @relation(fields: [clientId], references: [id])
  slotId   String        @unique
  slot     TimeSlot      @relation(fields: [slotId], references: [id])
  status   String        @default("PENDING")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}




