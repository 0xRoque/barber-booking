datasource db {
  provider = "sqlite"
}
generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

model User{
  id String @id @default(cuid())
  name String?
  email String @unique
  role Role @default(CLIENT)
  image String?
  timeSlots TimeSlot[]
  bookings Booking[]
}

model TimeSlot{
  id String @id @default(cuid())
  barberId String
  barber User @relation(fields : [barberId], references:[id])
  date DateTime 
  startTime DateTime 
  endTime DateTime
  isBlocked Boolean
  booking Booking?

}

model Booking{
  id String @id @default(cuid())
  clientId String
  client User @relation(fields : [clientId], references: [id])
  slotId String @unique 
  slot TimeSlot @relation(fields :[slotId], references:[id])
  status BookingStatus @default(PENDING)
}

enum BookingStatus{
  PENDING
  CONFIRMED
  CANCELLED
}

enum Role{
  CLIENT
  BARBER
}

